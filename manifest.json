{
  "manifest_version": 3,
  "name": "Mosaic",
  "short_name": "Mosaic",
  "version": "1.0.0",
  "description": "Minimal new tab with a bento grid. Add shortcuts, drag to reorder, favicons auto-load. Dark & light themes.",
  "homepage_url": "https://github.com/adi-uchiha/mosaic",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_title": "Mosaic New Tab",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

